{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ is_new ? 'Nouvel avis' : avis.titre }} — Administration CNCDP{% endblock %}

{% block admin_body %}
    <div class="admin-page-header">
        <p class="breadcrumb">
            <a href="{{ path('admin_dashboard') }}">Administration</a> &rsaquo;
            <a href="{{ path('admin_avis_list') }}">Avis</a> &rsaquo;
            {{ is_new ? 'Nouvel avis' : 'Modifier : ' ~ avis.titre }}
        </p>
        <div style="display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:1rem;">
            <h1>{{ is_new ? 'Créer un nouvel avis' : avis.titre }}</h1>
            <div style="display:flex;gap:0.5rem;">
                <button type="submit" form="avis-form" class="btn-admin btn-admin-primary">
                    <i class="fa-solid fa-check" aria-hidden="true"></i>
                    {{ is_new ? 'Créer' : 'Enregistrer' }}
                </button>
                <a href="{{ path('admin_avis_list') }}" class="btn-admin btn-admin-outline">Annuler</a>
            </div>
        </div>
    </div>

    <div class="admin-content">
        {% for error in errors %}
            <div class="admin-alert admin-alert-danger" role="alert">
                <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
                {{ error }}
            </div>
        {% endfor %}

        <form method="post" enctype="multipart/form-data" id="avis-form">
            <div class="admin-grid" style="grid-template-columns: 1fr 340px; gap: 1.5rem; align-items: start;">
                {# ===== COLONNE PRINCIPALE ===== #}
                <div>
                    {# Identité de l'avis #}
                    <div class="admin-card" style="margin-bottom: 1.5rem;">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-file-lines" aria-hidden="true" style="color:#9d38da;"></i> Identité de l'avis</h2>
                        </div>
                        <div class="admin-card-body">
                            <div class="admin-grid" style="grid-template-columns: 140px 1fr; gap: 1rem;">
                                <div class="admin-form-group">
                                    <label for="numero">Numéro <span style="color:#9d38da;">*</span></label>
                                    <input type="text" id="numero" name="numero" class="admin-form-control" value="{{ avis.numero }}" placeholder="2024-01" required maxlength="50">
                                </div>
                                <div class="admin-form-group">
                                    <label for="titre">Titre <span style="color:#9d38da;">*</span></label>
                                    <input type="text" id="titre" name="titre" class="admin-form-control" value="{{ avis.titre }}" placeholder="Titre complet de l'avis" required maxlength="255">
                                </div>
                            </div>
                            <div class="admin-grid" style="grid-template-columns: 1fr 1fr; gap: 1rem;">
                                <div class="admin-form-group">
                                    <label for="date_avis">Date <span style="color:#9d38da;">*</span></label>
                                    <input type="date" id="date_avis" name="date_avis" class="admin-form-control" value="{{ avis.dateAvis ? avis.dateAvis|date('Y-m-d') : '' }}" required>
                                </div>
                                <div class="admin-form-group">
                                    <label for="slug">Slug URL</label>
                                    <input type="text" id="slug" name="slug" class="admin-form-control" value="{{ avis.slug }}" placeholder="slug-de-l-avis" pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$" maxlength="255">
                                    <p class="form-hint" style="margin-top:0.25rem;">Laissez vide pour génération automatique.</p>
                                </div>
                            </div>
                        </div>
                    </div>

                    {# Contenu #}
                    <div class="admin-card" style="margin-bottom: 1.5rem;">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-pen-to-square" aria-hidden="true" style="color:#9d38da;"></i> Contenu</h2>
                        </div>
                        <div class="admin-card-body">
                            <div class="admin-form-group">
                                <label for="resume">Résumé</label>
                                <textarea id="resume" name="resume" class="admin-form-control" rows="4" placeholder="Résumé affiché dans la liste publique…">{{ avis.resume }}</textarea>
                                <p class="form-hint" style="margin-top:0.25rem;">Texte court (2-3 phrases). Affiché sur la page de consultation.</p>
                            </div>
                            <div class="admin-form-group" style="margin-bottom:0;">
                                <label for="contenu">Contenu complet</label>
                                <textarea id="contenu" name="contenu" class="admin-form-control" rows="14" placeholder="Contenu détaillé de l'avis…">{{ avis.contenu }}</textarea>
                                <p class="form-hint" style="margin-top:0.25rem;">HTML autorisé : &lt;p&gt;, &lt;strong&gt;, &lt;em&gt;, &lt;ul&gt;, &lt;ol&gt;, &lt;blockquote&gt;, &lt;h2&gt;-&lt;h4&gt;.</p>
                            </div>
                        </div>
                    </div>
                </div>

                {# ===== COLONNE LATÉRALE ===== #}
                <div>
                    {# Publication #}
                    <div class="admin-card" style="margin-bottom: 1.5rem;">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-eye" aria-hidden="true" style="color:#9d38da;"></i> Publication</h2>
                        </div>
                        <div class="admin-card-body">
                            <div class="admin-form-group" style="margin-bottom:0;">
                                <label for="status">Statut</label>
                                <select id="status" name="status" class="admin-form-control">
                                    <option value="draft" {{ avis.status == 'draft' ? 'selected' : '' }}>🟡 Brouillon</option>
                                    <option value="published" {{ avis.status == 'published' ? 'selected' : '' }}>🟢 Publié</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    {# PDF #}
                    <div class="admin-card" style="margin-bottom: 1.5rem;">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-file-pdf" aria-hidden="true" style="color:#9d38da;"></i> Document PDF</h2>
                        </div>
                        <div class="admin-card-body">
                            {% if avis.pdfFilename %}
                                <div style="display:flex;align-items:center;gap:0.5rem;margin-bottom:0.75rem;padding:0.5rem 0.75rem;background:#f4f0fa;border-radius:6px;">
                                    <i class="fa-solid fa-file-pdf" aria-hidden="true" style="color:#9d38da;"></i>
                                    <span style="font-size:0.85rem;flex:1;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">{{ avis.pdfFilename }}</span>
                                    <button type="submit" form="delete-pdf-form" class="btn-admin btn-admin-danger btn-admin-sm" title="Supprimer le PDF" style="flex-shrink:0;">
                                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                    </button>
                                </div>
                            {% endif %}
                            <div class="admin-form-group" style="margin-bottom:0;">
                                <label for="pdf_file">{% if avis.pdfFilename %}Remplacer le fichier{% else %}Importer un PDF{% endif %}</label>
                                <input type="file" id="pdf_file" name="pdf_file" class="admin-form-control" accept="application/pdf" style="padding:0.5rem;">
                                <p class="form-hint" style="margin-top:0.25rem;">PDF uniquement.</p>
                            </div>
                        </div>
                    </div>

                    {# Critères #}
                    <div class="admin-card" style="margin-bottom: 1.5rem;">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-tags" aria-hidden="true" style="color:#9d38da;"></i> Critères</h2>
                        </div>
                        <div class="admin-card-body">
                            {% if criteres_disponibles is empty %}
                                <p class="admin-text-muted" style="font-size:0.85rem;">Aucun critère défini.</p>
                                <a href="{{ path('admin_criteres_list') }}" class="btn-admin btn-admin-outline btn-admin-sm" style="margin-top:0.5rem;">Gérer les critères</a>
                            {% else %}
                                {% for critere in criteres_disponibles %}
                                    {% if critere.valeursActives is not empty %}
                                    <div class="admin-form-group" style="{% if loop.last %}margin-bottom:0;{% endif %}">
                                        <label>{{ critere.nom }}</label>
                                        <div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
                                            {% for valeur in critere.valeursActives %}
                                                <label style="display:flex;align-items:center;gap:0.35rem;font-size:0.8rem;cursor:pointer;padding:0.35rem 0.65rem;border:1px solid #e0d8e8;border-radius:6px;background:#faf8fc;transition:all 0.15s;user-select:none;">
                                                    <input type="checkbox" name="criteres_valeurs[]" value="{{ valeur.id }}"
                                                        {{ valeur.id in avis.criteres|map(cv => cv.id) ? 'checked' : '' }}
                                                        style="accent-color:#9d38da;">
                                                    {{ valeur.valeur }}
                                                </label>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    {% endif %}
                                {% endfor %}
                                <a href="{{ path('admin_criteres_list') }}" style="font-size:0.75rem;color:#9d38da;text-decoration:none;display:inline-block;margin-top:0.5rem;">
                                    <i class="fa-solid fa-gear" aria-hidden="true"></i> Gérer les critères
                                </a>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        </form>

        {% if avis.pdfFilename %}
        <form method="post" action="{{ path('admin_avis_delete_pdf', {id: avis.id}) }}" id="delete-pdf-form" style="display:none;">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_pdf_' ~ avis.id) }}">
        </form>
        {% endif %}
    </div>
{% endblock %}
