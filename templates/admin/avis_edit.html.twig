{% extends 'admin/base_admin.html.twig' %}

{% block title %}{{ is_new ? 'Nouvel avis' : avis.titre }} — Administration CNCDP{% endblock %}

{% block admin_body %}
    <div class="admin-page-header">
        <p class="breadcrumb">
            <a href="{{ path('admin_dashboard') }}">Administration</a> &rsaquo;
            <a href="{{ path('admin_avis_list') }}">Avis</a> &rsaquo;
            {{ is_new ? 'Nouvel avis' : avis.titre }}
        </p>
        <h1>{{ is_new ? 'Créer un nouvel avis' : 'Modifier : ' ~ avis.titre }}</h1>
    </div>

    <div class="admin-content">
        {% for error in errors %}
            <div class="admin-alert admin-alert-danger" role="alert">
                <i class="fa-solid fa-circle-exclamation" aria-hidden="true"></i>
                {{ error }}
            </div>
        {% endfor %}

        <form method="post" enctype="multipart/form-data" id="avis-form">
            <div class="admin-grid" style="grid-template-columns: 2fr 1fr;">
                {# Colonne principale #}
                <div>
                    <div class="admin-card admin-mb-3">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-file-lines" aria-hidden="true"></i> Contenu de l'avis</h2>
                        </div>
                        <div class="admin-card-body">
                            <div class="admin-form-group">
                                <label for="numero">Numéro <span style="color:var(--orange-vif);">*</span></label>
                                <input type="text" id="numero" name="numero" class="admin-input" value="{{ avis.numero }}" placeholder="Ex: 2024-01" required maxlength="50">
                                <small class="admin-text-muted">Numéro officiel de l'avis (unique).</small>
                            </div>

                            <div class="admin-form-group">
                                <label for="titre">Titre <span style="color:var(--orange-vif);">*</span></label>
                                <input type="text" id="titre" name="titre" class="admin-input" value="{{ avis.titre }}" placeholder="Titre complet de l'avis" required maxlength="255">
                            </div>

                            <div class="admin-form-group">
                                <label for="slug">Slug URL</label>
                                <input type="text" id="slug" name="slug" class="admin-input" value="{{ avis.slug }}" placeholder="slug-de-l-avis" pattern="^[a-z0-9]+(?:-[a-z0-9]+)*$" maxlength="255">
                                <small class="admin-text-muted">Laissez vide pour génération automatique depuis le titre.</small>
                            </div>

                            <div class="admin-form-group">
                                <label for="date_avis">Date de l'avis <span style="color:var(--orange-vif);">*</span></label>
                                <input type="date" id="date_avis" name="date_avis" class="admin-input" value="{{ avis.dateAvis ? avis.dateAvis|date('Y-m-d') : '' }}" required>
                            </div>

                            <div class="admin-form-group">
                                <label for="resume">Résumé</label>
                                <textarea id="resume" name="resume" class="admin-input admin-textarea" rows="4" placeholder="Résumé court affiché sur la carte dans la liste publique...">{{ avis.resume }}</textarea>
                            </div>

                            <div class="admin-form-group">
                                <label for="contenu">Contenu complet (HTML)</label>
                                <textarea id="contenu" name="contenu" class="admin-input admin-textarea" rows="12" placeholder="<p>Contenu détaillé de l'avis...</p>">{{ avis.contenu }}</textarea>
                                <small class="admin-text-muted">Vous pouvez utiliser des balises HTML simples (&lt;p&gt;, &lt;strong&gt;, &lt;ul&gt;, etc.).</small>
                            </div>
                        </div>
                    </div>
                </div>

                {# Colonne latérale #}
                <div>
                    {# Statut & Publication #}
                    <div class="admin-card admin-mb-3">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-gear" aria-hidden="true"></i> Publication</h2>
                        </div>
                        <div class="admin-card-body">
                            <div class="admin-form-group">
                                <label for="status">Statut</label>
                                <select id="status" name="status" class="admin-input">
                                    <option value="draft" {{ avis.status == 'draft' ? 'selected' : '' }}>Brouillon</option>
                                    <option value="published" {{ avis.status == 'published' ? 'selected' : '' }}>Publié</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    {# PDF #}
                    <div class="admin-card admin-mb-3">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-file-pdf" aria-hidden="true"></i> Document PDF</h2>
                        </div>
                        <div class="admin-card-body">
                            {% if avis.pdfFilename %}
                                <div class="admin-mb-2">
                                    <span class="admin-badge admin-badge-success">
                                        <i class="fa-solid fa-file-pdf" aria-hidden="true"></i>
                                        {{ avis.pdfFilename }}
                                    </span>
                                    <button type="submit" form="delete-pdf-form" class="btn-admin btn-admin-danger btn-admin-sm" style="margin-left:0.5rem;" title="Supprimer le PDF">
                                        <i class="fa-solid fa-trash" aria-hidden="true"></i>
                                    </button>
                                </div>
                            {% else %}
                                <p class="admin-text-muted admin-mb-2">Aucun PDF associé.</p>
                            {% endif %}

                            <div class="admin-form-group">
                                <label for="pdf_file">
                                    {% if avis.pdfFilename %}
                                        Remplacer le PDF
                                    {% else %}
                                        Importer un PDF
                                    {% endif %}
                                </label>
                                <input type="file" id="pdf_file" name="pdf_file" class="admin-input" accept="application/pdf">
                                <small class="admin-text-muted">Format accepté : PDF uniquement.</small>
                            </div>
                        </div>
                    </div>

                    {# Critères / Tags #}
                    <div class="admin-card admin-mb-3">
                        <div class="admin-card-header">
                            <h2><i class="fa-solid fa-tags" aria-hidden="true"></i> Critères</h2>
                        </div>
                        <div class="admin-card-body">
                            {% if criteres_disponibles is empty %}
                                <p class="admin-text-muted">Aucun critère défini. <a href="{{ path('admin_criteres_list') }}">Créer des critères</a>.</p>
                            {% else %}
                                {% set selectedIds = avis.criteres|map(cv => cv.id)|join(',') %}
                                {% for critere in criteres_disponibles %}
                                    {% if critere.valeursActives is not empty %}
                                    <div class="admin-form-group">
                                        <label style="font-weight:600;">{{ critere.nom }}</label>
                                        <div style="display:flex;flex-wrap:wrap;gap:0.25rem;">
                                            {% for valeur in critere.valeursActives %}
                                                <label style="display:flex;align-items:center;gap:0.25rem;font-size:0.85rem;cursor:pointer;padding:0.2rem 0.5rem;border:1px solid #dee2e6;border-radius:4px;background:#f8f9fa;">
                                                    <input type="checkbox" name="criteres_valeurs[]" value="{{ valeur.id }}"
                                                        {{ valeur.id in avis.criteres|map(cv => cv.id) ? 'checked' : '' }}>
                                                    {{ valeur.valeur }}
                                                </label>
                                            {% endfor %}
                                        </div>
                                    </div>
                                    {% endif %}
                                {% endfor %}
                            {% endif %}
                            <small class="admin-text-muted">
                                <a href="{{ path('admin_criteres_list') }}">Gérer les critères et valeurs disponibles</a>
                            </small>
                        </div>
                    </div>

                    {# Actions #}
                    <div class="admin-card">
                        <div class="admin-card-body">
                            <button type="submit" class="btn-admin btn-admin-primary" style="width:100%;">
                                <i class="fa-solid fa-check" aria-hidden="true"></i>
                                {{ is_new ? 'Créer l\'avis' : 'Enregistrer' }}
                            </button>
                            <a href="{{ path('admin_avis_list') }}" class="btn-admin btn-admin-outline" style="width:100%;margin-top:0.5rem;">
                                Annuler
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </form>

        {# Formulaire caché pour suppression du PDF #}
        {% if avis.pdfFilename %}
        <form method="post" action="{{ path('admin_avis_delete_pdf', {id: avis.id}) }}" id="delete-pdf-form" style="display:none;">
            <input type="hidden" name="_token" value="{{ csrf_token('delete_pdf_' ~ avis.id) }}">
        </form>
        {% endif %}
    </div>
{% endblock %}
