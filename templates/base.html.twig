<!DOCTYPE html>
<html lang="fr">
    <head>
        <meta charset="UTF-8">
        <meta name="viewport" content="width=device-width, initial-scale=1.0">
        <title>{% block title %}CNCDP — Comité National Consultatif de Déontologie des Psychologues{% endblock %}</title>
        <meta name="description" content="{% block meta_description %}Le Comité National Consultatif de Déontologie des Psychologues (CNCDP) veille au respect du Code de déontologie des psychologues en France.{% endblock %}">
        <link rel="icon" href="data:image/svg+xml,<svg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 128 128%22><text y=%221.2em%22 font-size=%2296%22>🧠</text></svg>">

        {# FontAwesome 6 (icônes) #}
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" integrity="sha512-DTOQO9RWCH3ppGqcWaEA1BIZOC6xxalwEsw9c2QQeAIftl+Vegovlnee1c9QX4TctnWMn13TZye+giMm8e2LwA==" crossorigin="anonymous" referrerpolicy="no-referrer">

        {% block stylesheets %}
            {# Bootstrap 4.6 — framework global du site (cohérent avec l'éditeur) #}
            <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/css/bootstrap.min.css">
            {# CNCDP — surcharge couleurs/variables #}
            <link rel="stylesheet" href="{{ asset('styles/cncdp.css') }}">
        {% endblock %}

        {% block javascripts %}
            {% block importmap %}{{ importmap('app') }}{% endblock %}
            {# jQuery + Bootstrap 4.6 JS (necessaires pour carousel, accordion, etc.) #}
            <script src="https://code.jquery.com/jquery-3.6.4.slim.min.js" crossorigin="anonymous"></script>
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@4.6.2/dist/js/bootstrap.bundle.min.js"></script>
        {% endblock %}

        {% set frankenphpHotReload = app.request.server.get('FRANKENPHP_HOT_RELOAD') %}
        {% if frankenphpHotReload %}
        <meta name="frankenphp-hot-reload:url" content="{{ frankenphpHotReload }}">
        <script src="https://cdn.jsdelivr.net/npm/idiomorph"></script>
        <script src="https://cdn.jsdelivr.net/npm/frankenphp-hot-reload/+esm" type="module"></script>
        {% endif %}
    </head>
    <body>
        {# Macro récursive pour le rendu du menu (supporte une profondeur illimitée) #}
        {% macro menu_item(item) %}
            <li class="nav-item{% if item.children|length > 0 %} has-submenu{% endif %}">
                <a href="{{ item.url }}">{{ item.label }}</a>
                {% if item.children|length > 0 %}
                    <ul class="submenu">
                        {% for child in item.children %}
                            {{ _self.menu_item(child) }}
                        {% endfor %}
                    </ul>
                {% endif %}
            </li>
        {% endmacro %}

        {# ===== HEADER & NAVIGATION ===== #}
        <header class="site-header" role="banner">
            <div class="container header-inner">
                <a href="{{ path('app_home') }}" class="header-brand" aria-label="CNCDP — Accueil">
                    <img src="{{ asset('images/' ~ site_config().logo) }}" alt="Logo CNCDP" class="brand-logo" width="48" height="48">
                </a>

                <input type="checkbox" id="menu-toggle" class="menu-toggle" aria-hidden="true">
                <label for="menu-toggle" class="menu-toggle-label" aria-label="Menu de navigation" tabindex="0" role="button">
                    <i class="fa-solid fa-bars" aria-hidden="true"></i>
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i>
                </label>

                <nav class="main-nav" role="navigation" aria-label="Navigation principale">
                    <ul class="nav-list">
                        {% set menu = menu_config() %}
                        {% import _self as macros %}
                        {% for item in menu.items %}
                            {{ macros.menu_item(item) }}
                        {% endfor %}
                    </ul>
                </nav>
            </div>
        </header>

        {% block body %}{% endblock %}

        {# Footer commun — dynamique via admin #}
        {% set footer = footer_config() %}
        <footer class="site-footer" role="contentinfo">
            <div class="container">
                <div class="footer-grid">
                    <div class="footer-col">
                        <h4>CNCDP</h4>
                        <address>
                            {{ footer.address|nl2br }}
                        </address>
                    </div>
                    <div class="footer-col">
                        <h4>Contact</h4>
                        {% if footer.email %}
                        <p>
                            <i class="fa-solid fa-envelope" aria-hidden="true"></i>
                            <a href="mailto:{{ footer.email }}">{{ footer.email }}</a>
                        </p>
                        {% endif %}
                        {% for line in footer.contact_links|default('')|split('\n')|filter(l => l|trim is not empty) %}
                            {% set parts = line|split('|') %}
                            {% if parts|length >= 2 %}
                            <p><a href="{{ parts[1]|trim }}">{{ parts[0]|trim }}</a></p>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <div class="footer-col">
                        <h4>Liens utiles</h4>
                        {% for line in footer.links|split('\n')|filter(l => l|trim is not empty) %}
                            {% set parts = line|split('|') %}
                            {% if parts|length >= 2 %}
                            <p><a href="{{ parts[1]|trim }}">{{ parts[0]|trim }}</a></p>
                            {% endif %}
                        {% endfor %}
                    </div>
                </div>
                <div class="footer-bottom">
                    <div class="footer-legal">
                        {% for line in footer.bottom_links|split('\n')|filter(l => l|trim is not empty) %}
                            {% set parts = line|split('|') %}
                            {% if parts|length >= 2 %}
                            <a href="{{ parts[1]|trim }}">{{ parts[0]|trim }}</a>
                            {% endif %}
                        {% endfor %}
                    </div>
                    <p class="footer-copyright">{{ footer.bottom_text|default('© ' ~ 'now'|date('Y') ~ ' CNCDP — Tous droits réservés') }}</p>
                </div>
            </div>
        </footer>
    </body>
</html>
