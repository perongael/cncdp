{% extends 'base.html.twig' %}

{% block title %}Consultation des avis — CNCDP{% endblock %}

{% block meta_description %}Consultez les avis déontologiques rendus par le Comité National Consultatif de Déontologie des Psychologues. Recherchez par numéro, année, thématique ou mot-clé.{% endblock %}

{% block body %}
{# ===== HERO ===== #}
<section class="avis-hero" style="background: linear-gradient(135deg, #2d2540 0%, #9d38da 50%, #9335e4 100%);padding:4rem 0 3rem;color:#fff;position:relative;overflow:hidden;">
    <div style="position:absolute;top:-100px;right:-100px;width:350px;height:350px;border-radius:50%;background:radial-gradient(circle, rgba(253,130,187,0.25) 0%, transparent 70%);pointer-events:none;"></div>
    <div style="position:absolute;bottom:-80px;left:-80px;width:300px;height:300px;border-radius:50%;background:radial-gradient(circle, rgba(222,109,17,0.2) 0%, transparent 70%);pointer-events:none;"></div>
    <div class="container" style="position:relative;z-index:1;">
        <div class="row">
            <div class="col-lg-8">
                <h1 style="font-size:2.5rem;font-weight:800;margin-bottom:0.75rem;text-shadow:0 2px 12px rgba(0,0,0,0.3);">Consultation des avis</h1>
                <p style="font-size:1.15rem;opacity:0.9;margin-bottom:0;text-shadow:0 1px 6px rgba(0,0,0,0.25);">
                    Retrouvez l'ensemble des avis consultatifs rendus par le CNCDP depuis sa création. Chaque avis éclaire une question déontologique soumise par un psychologue, une organisation ou une institution.
                </p>
            </div>
            <div class="col-lg-4 d-none d-lg-flex align-items-center justify-content-center">
                <i class="fa-solid fa-scale-balanced" aria-hidden="true" style="font-size:5rem;opacity:0.2;"></i>
            </div>
        </div>
    </div>
</section>

{# ===== RECHERCHE & FILTRES ===== #}
<section style="background:#f8f9fa;padding:1.5rem 0;border-bottom:1px solid #dee2e6;">
    <div class="container">
        <form method="get" action="{{ path('app_avis_index') }}" id="avis-filters">
            {# Barre de recherche #}
            <div class="row mb-3">
                <div class="col-md-8">
                    <div style="position:relative;">
                        <i class="fa-solid fa-magnifying-glass" aria-hidden="true" style="position:absolute;left:1rem;top:50%;transform:translateY(-50%);color:#9d38da;"></i>
                        <input type="search" name="q" class="form-control" value="{{ filters.q|default('') }}" placeholder="Rechercher par numéro, titre, résumé ou mot-clé..." style="padding-left:2.75rem;border:2px solid #dee2e6;border-radius:8px;font-size:1rem;height:3rem;">
                    </div>
                </div>
                <div class="col-md-4 mt-2 mt-md-0">
                    <select name="annee" class="form-control" style="border:2px solid #dee2e6;border-radius:8px;height:3rem;">
                        <option value="">Toutes les années</option>
                        {% for annee in annees %}
                            <option value="{{ annee }}" {{ filters.annee == annee ? 'selected' : '' }}>{{ annee }}</option>
                        {% endfor %}
                    </select>
                </div>
            </div>

            {# Filtres par critères #}
            {% if criteres is not empty %}
            <div class="row">
                {% for critere in criteres %}
                    {% if critere.valeursActives is not empty %}
                    <div class="col-md-4 col-lg-3 mb-2">
                        <div style="font-weight:600;font-size:0.8rem;color:#6c757d;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.25rem;">{{ critere.nom }}</div>
                        <select name="criteres[]" class="form-control form-control-sm" style="border-radius:6px;" onchange="this.form.submit();">
                            <option value="">Tous</option>
                            {% for valeur in critere.valeursActives %}
                                <option value="{{ valeur.id }}" {{ valeur.id in filters.criteres|default([]) ? 'selected' : '' }}>{{ valeur.valeur }}</option>
                            {% endfor %}
                        </select>
                    </div>
                    {% endif %}
                {% endfor %}
            </div>
            {% endif %}

            {# Filtres actifs + réinitialisation #}
            {% if filters.q or filters.annee or filters.criteres|default([])|length > 0 %}
            <div class="mt-3 d-flex align-items-center flex-wrap" style="gap:0.5rem;">
                <span style="font-size:0.85rem;color:#6c757d;">Filtres actifs :</span>
                {% if filters.q %}
                    <span class="badge" style="background:#9d38da;color:#fff;font-size:0.8rem;padding:0.35rem 0.75rem;border-radius:20px;">
                        Recherche : {{ filters.q }}
                    </span>
                {% endif %}
                {% if filters.annee %}
                    <span class="badge" style="background:#9335e4;color:#fff;font-size:0.8rem;padding:0.35rem 0.75rem;border-radius:20px;">
                        Année : {{ filters.annee }}
                    </span>
                {% endif %}
                <a href="{{ path('app_avis_index') }}" class="btn btn-sm" style="background:#de6d11;color:#fff;border-radius:20px;font-size:0.8rem;padding:0.35rem 1rem;">
                    <i class="fa-solid fa-xmark" aria-hidden="true"></i> Réinitialiser
                </a>
            </div>
            {% endif %}
        </form>
    </div>
</section>

{# ===== LISTE DES AVIS ===== #}
<section style="padding:2.5rem 0;background:#fafafa;">
    <div class="container">
        {% if avis_list is empty %}
            <div style="text-align:center;padding:4rem 1rem;">
                <i class="fa-solid fa-scale-balanced" aria-hidden="true" style="font-size:2.5rem;color:#e9ecef;display:block;margin-bottom:1rem;"></i>
                <h3 style="color:#6c757d;font-weight:500;">Aucun avis trouvé</h3>
                <p style="color:#adb5bd;">
                    {% if filters.q or filters.annee or filters.criteres|default([])|length > 0 %}
                        Essayez de modifier vos critères de recherche.
                    {% else %}
                        Les avis consultatifs seront publiés prochainement.
                    {% endif %}
                </p>
                {% if filters.q or filters.annee or filters.criteres|default([])|length > 0 %}
                    <a href="{{ path('app_avis_index') }}" class="btn btn-outline-secondary btn-sm mt-2">Réinitialiser les filtres</a>
                {% endif %}
            </div>
        {% else %}
            <p style="color:#6c757d;font-size:0.85rem;margin-bottom:1.5rem;">
                <strong>{{ avis_list|length }}</strong> avis trouvé(s)
            </p>

            <div style="background:#fff;border:1px solid #e9ecef;border-radius:10px;overflow:hidden;">
                {% for avis in avis_list %}
                <div style="padding:1.5rem;{% if not loop.last %}border-bottom:1px solid #f0f0f0;{% endif %}display:flex;gap:1.5rem;align-items:flex-start;transition:background 0.15s;" onmouseover="this.style.background='#fdfbff'" onmouseout="this.style.background=''">
                    {# Colonne gauche : méta #}
                    <div style="flex-shrink:0;width:100px;text-align:right;">
                        <div style="font-size:0.75rem;color:#adb5bd;text-transform:uppercase;letter-spacing:0.05em;margin-bottom:0.25rem;">{{ avis.dateAvis|date('d/m/Y') }}</div>
                        <code style="background:#f4f0fa;color:#7c3aed;font-size:0.8rem;padding:0.2rem 0.5rem;border-radius:4px;font-weight:600;">{{ avis.numero }}</code>
                    </div>

                    {# Colonne centrale : contenu #}
                    <div style="flex:1;min-width:0;">
                        <h2 style="font-size:1.1rem;font-weight:600;line-height:1.4;margin:0 0 0.5rem 0;">
                            <a href="{{ path('app_avis_show', {slug: avis.slug}) }}" style="color:#2d2540;text-decoration:none;">
                                {{ avis.titre }}
                            </a>
                        </h2>
                        {% if avis.resume %}
                            <p style="color:#495057;font-size:0.9rem;line-height:1.65;margin-bottom:0.75rem;">
                                {{ avis.resume }}
                            </p>
                        {% endif %}
                        {% if avis.criteres|length > 0 %}
                        <div style="display:flex;flex-wrap:wrap;gap:0.35rem;">
                            {% for cv in avis.criteres|slice(0, 6) %}
                                <span style="background:#f4f0fa;color:#7c3aed;font-size:0.7rem;padding:0.15rem 0.55rem;border-radius:20px;white-space:nowrap;">{{ cv.valeur }}</span>
                            {% endfor %}
                            {% if avis.criteres|length > 6 %}
                                <span style="font-size:0.7rem;color:#adb5bd;">+{{ avis.criteres|length - 6 }}</span>
                            {% endif %}
                        </div>
                        {% endif %}
                    </div>

                    {# Colonne droite : action #}
                    <div style="flex-shrink:0;display:flex;align-items:center;">
                        <a href="{{ path('app_avis_show', {slug: avis.slug}) }}" style="display:inline-flex;align-items:center;gap:0.35rem;color:#9d38da;text-decoration:none;font-size:0.85rem;font-weight:500;white-space:nowrap;padding:0.4rem 0.75rem;border:1px solid #e8dff5;border-radius:6px;transition:all 0.15s;" onmouseover="this.style.background='#9d38da';this.style.color='#fff';this.style.borderColor='#9d38da'" onmouseout="this.style.background='';this.style.color='#9d38da';this.style.borderColor='#e8dff5'">
                            Lire
                            <i class="fa-solid fa-arrow-right" aria-hidden="true" style="font-size:0.7rem;"></i>
                        </a>
                    </div>
                </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
</section>
{% endblock %}
